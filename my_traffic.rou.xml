    <flow id="right_left"     type="standard_car" begin="0" end="3600" probability="0.02" from="E18" to="-E19"/>

    <flow id="amb_top" type="ambulance" begin="0" end="3600" probability="0.005" from="E17" to="-E19"/>
    
    <flow id="amb_left" type="ambulance" begin="0" end="3600" probability="0.005" from="E16" to="-E18"/>

</routes>